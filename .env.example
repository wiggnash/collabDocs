# ─────────────────────────────────────────────────────────────
# CollabDocs environment template.
# Copy to .env and fill in real values:  cp .env.example .env
# NEVER commit the real .env — it is git-ignored. This file is.
# ─────────────────────────────────────────────────────────────

# ─── Django core ───
# Generate a fresh one with:
#   uv run python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
SECRET_KEY=replace-me-with-a-long-random-string

# Cast safely by env.bool(); accepts True/False, 1/0, yes/no.
DEBUG=True

# Comma-separated. Empty is fine while DEBUG=True.
ALLOWED_HOSTS=127.0.0.1,localhost

# ─── Database switch ───
# NODB toggles which database backend settings.py builds:
#   NODB=True   → file-based SQLite (zero-setup, the dev default; no DB server to run)
#   NODB=False  → PostgreSQL, configured from DATABASE_URL below
# Develop on SQLite; flip to False for the PostgreSQL submission pass.
NODB=True

# Only read when NODB=False. Format: postgres://USER:PASSWORD@HOST:PORT/NAME
DATABASE_URL=postgres://collabdocs:password@localhost:5432/collabdocs
